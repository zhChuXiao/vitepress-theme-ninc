{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "vitepress-theme-ninc": ["./packages/theme/src/index.ts"],
      "vitepress-theme-ninc/*": ["./packages/theme/src/*"]
    }
  }
}
